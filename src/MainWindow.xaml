<Window x:Class="Nopad.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Nopad"
        Title="Untitled - Nopad"
        Width="800" Height="600"
        Icon="pack://application:,,,/notepad.ico"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New" InputGestureText="Ctrl+N" Click="New_Click"/>
                <MenuItem Header="_Open..." InputGestureText="Ctrl+O" Click="Open_Click"/>
                <MenuItem Header="_Save" InputGestureText="Ctrl+S" Click="Save_Click"/>
                <MenuItem Header="Save _As..." InputGestureText="Ctrl+Shift+S" Click="SaveAs_Click"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" InputGestureText="Ctrl+Z" Click="Undo_Click"/>
                <MenuItem Header="_Redo" InputGestureText="Ctrl+Y" Click="Redo_Click"/>
                <Separator/>
                <MenuItem Header="Cu_t" InputGestureText="Ctrl+X" Click="Cut_Click"/>
                <MenuItem Header="_Copy" InputGestureText="Ctrl+C" Click="Copy_Click"/>
                <MenuItem Header="_Paste" InputGestureText="Ctrl+V" Click="Paste_Click"/>
                <MenuItem Header="_Delete" InputGestureText="Del" Click="Delete_Click"/>
                <Separator/>
                <MenuItem Header="_Find..." InputGestureText="Ctrl+F" Click="Find_Click"/>
                <MenuItem Header="_Replace..." InputGestureText="Ctrl+H" Click="Replace_Click"/>
                <Separator/>
                <MenuItem Header="Select _All" InputGestureText="Ctrl+A" Click="SelectAll_Click"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Zoom _In" InputGestureText="Ctrl+Plus" Click="ZoomIn_Click"/>
                <MenuItem Header="Zoom _Out" InputGestureText="Ctrl+Minus" Click="ZoomOut_Click"/>
                <MenuItem Header="_Reset Zoom" InputGestureText="Ctrl+0" Click="ZoomReset_Click"/>
                <Separator/>
                <MenuItem x:Name="WordWrapMenuItem" Header="_Word Wrap" IsCheckable="True"
                          Checked="WordWrap_Changed" Unchecked="WordWrap_Changed"/>
                <MenuItem x:Name="LineNumbersMenuItem" Header="_Line Numbers" IsCheckable="True"
                          Checked="LineNumbers_Changed" Unchecked="LineNumbers_Changed"/>
                <MenuItem x:Name="StatusBarMenuItem" Header="_Status Bar" IsCheckable="True" IsChecked="True"
                          Checked="StatusBar_Changed" Unchecked="StatusBar_Changed"/>
            </MenuItem>
        </Menu>

        <!-- Status Bar -->
        <StatusBar x:Name="AppStatusBar" DockPanel.Dock="Bottom" Padding="4,1" FontSize="12">
            <StatusBarItem Padding="4,0">
                <TextBlock x:Name="StatusLineCol" Text="Ln 1, Col 1"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem Padding="4,0">
                <TextBlock x:Name="StatusCharCount" Text="0 Characters"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem Padding="4,0">
                <TextBlock x:Name="StatusZoom" Text="100%"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem Padding="4,0">
                <TextBlock x:Name="StatusLineEnding" Text="Windows (CRLF)"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem Padding="4,0">
                <TextBlock x:Name="StatusEncoding" Text="UTF-8"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Editor Area with floating Find/Replace overlay -->
        <Grid>
            <!-- Editor + Line Numbers (bottom layer) -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="LineNumberColumn" Width="0"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Line Number Gutter -->
                <ScrollViewer x:Name="LineNumberScroller" Grid.Column="0"
                              VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Hidden"
                              IsHitTestVisible="False">
                    <TextBlock x:Name="LineNumberText"
                               FontFamily="Consolas" FontSize="14"
                               TextAlignment="Right" Padding="8,0,8,0"
                               VerticalAlignment="Top"/>
                </ScrollViewer>

                <!-- Text Editor -->
                <TextBox x:Name="Editor" Grid.Column="1"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         UndoLimit="500"
                         FontFamily="Consolas"
                         FontSize="14"
                         BorderThickness="0"
                         Padding="20,0"
                         SelectionBrush="#0078D7"
                         TextChanged="Editor_TextChanged"
                         SelectionChanged="Editor_SelectionChanged"
                         PreviewKeyDown="Editor_PreviewKeyDown"
                         PreviewMouseWheel="Editor_PreviewMouseWheel"/>
            </Grid>

            <!-- Floating Find/Replace panel (overlay) -->
            <local:FindReplaceControl x:Name="FindReplaceBar"
                                      HorizontalAlignment="Right" VerticalAlignment="Top"
                                      Margin="0,4,20,0"/>
        </Grid>
    </DockPanel>
</Window>
